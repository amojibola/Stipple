# ── Application ──────────────────────────────────────────────────────────────
FRONTEND_URL=                  # e.g. https://yourdomain.com (no trailing slash)

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=                   # database name, e.g. stipple
POSTGRES_USER=                 # database user, e.g. stipple
POSTGRES_PASSWORD=             # strong random password (openssl rand -hex 32)
DATABASE_URL=                  # postgresql+asyncpg://user:pass@postgres:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=                # strong random password (openssl rand -hex 32)
REDIS_BROKER_URL=              # redis://:password@redis:6379/0  — Celery broker + result backend
REDIS_AUTH_URL=                # redis://:password@redis:6379/1  — auth tokens + rate limiting
REDIS_CACHE_URL=               # redis://:password@redis:6379/2  — preview cache

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -i private.pem | tr -d '\n'  → paste as JWT_PRIVATE_KEY
#   base64 -i public.pem  | tr -d '\n'  → paste as JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=               # RS256 private key, PEM, base64-encoded (no newlines)
JWT_PUBLIC_KEY=                # RS256 public key,  PEM, base64-encoded (no newlines)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (SendGrid SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=                     # e.g. smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=                     # e.g. apikey  (literal string for SendGrid)
SMTP_PASSWORD=                 # SendGrid API key starting with SG.
EMAIL_FROM=                    # verified sender address, e.g. noreply@yourdomain.com

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local          # local (Phase 1). Change to s3 for Phase 2.
STORAGE_BASE_PATH=/app/volumes/uploads
OUTPUT_BASE_PATH=/app/volumes/outputs

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=             # same value as REDIS_BROKER_URL

# ── Flower (internal task monitoring — not exposed via Nginx) ─────────────────
FLOWER_USER=                   # basic auth username for Flower UI
FLOWER_PASSWORD=               # basic auth password for Flower UI

# ── Quotas (DB defaults; override per user in user_quotas table) ──────────────
DEFAULT_DAILY_RENDER_LIMIT=10
DEFAULT_MONTHLY_RENDER_LIMIT=100
